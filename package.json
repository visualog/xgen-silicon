{
  "name": "temp-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev -H 127.0.0.1",
    "electron:dev": "node electron/dev.mjs",
    "electron": "electron ./electron",
    "codex-worker": "node scripts/codex-worker.mjs",
    "collect:style-reference": "node scripts/collect-style-reference.mjs",
    "build:style-reference-library": "node scripts/build-style-reference-library.mjs",
    "build:next": "next build && node scripts/prepare-electron-package.mjs",
    "pack:mac": "npm run build:next && electron-builder --mac --dir",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@xyflow/react": "^12.10.2",
    "animejs": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/animejs": "^3.1.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.visualog.xgen",
    "productName": "xGen",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "next/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/codex-worker.mjs",
        "to": "codex-worker.mjs"
      }
    ],
    "mac": {
      "icon": "assets/BrandGen.icns",
      "target": [
        "dir"
      ],
      "category": "public.app-category.graphics-design"
    }
  }
}
